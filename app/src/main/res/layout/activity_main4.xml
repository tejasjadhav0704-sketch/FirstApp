<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/textView13"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NOT GONNA LIE 🙂‍↔️"
        android:textSize="34sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.127" />

    <androidx.cardview.widget.CardView
        android:id="@+id/card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="20dp"
        app:layout_constraintBottom_toTopOf="@id/textView14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textView13"
        app:layout_constraintVertical_bias="0.505">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="270dp"
            android:layout_marginTop="15dp">

            <TextView
                android:id="@+id/textView15"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="This app actually start hua tha ek simple idea se “bas ek login app bananaa tha, easy hoga krke start kiya.”But reality mein smjha Easy hai boht (iykyk)😭.ye phila App hai Solo making, UI maine Figma me design kiya, kyunki bina plan ke XML likhna matlab seedha chaos khud ke pairr pr khuladi marna.  isme Kotlin aur Firebase use kiya for backend, sab kuch tutorial me easy lagta hai, lekin real life me “error hi error” vo bhi ganghor error. Not gonna lie 😄, kaafi baar aisa hua ki code likha, run kiya, app crash hua, fir error aya , Google kiya aur kabhi kabhi run bhi ho jata (pata nahi kaise 😭). AI tools ka bhi kaafi role raha is project me — basically ek silent senior developer jaisa, jo har error pe samjha deta tha ki bhai yeh yahan galat hai. Total milake around 26 hours lage, jisme coding, designing, Firebase setup, sab akele “yeh kyun nahi chal raha” wala phase bhi included tha 🙂. End me app chal gaya — login bhi ho raha hai, signup bhi ho raha hai, aur Firebase bhi mostly behave kar raha hai. So haan, project complete ho gaya… thoda struggle ke saath, but ho gaya 🚀"
                android:textSize="15sp" />
        </ScrollView>

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/textView14"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="120dp"
        android:text="AT LAST 😁 I LEARNT A LOT"
        android:textSize="27sp"
        app:layout_constraintBottom_toTopOf="@id/button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView13"
        app:layout_constraintVertical_bias="1.0" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:background="@drawable/button_styling"
        android:text="GitHub"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.837" />

</androidx.constraintlayout.widget.ConstraintLayout>
